{
  "name": "@wisemapping/web2d",
  "version": "6.0.1",
  "description": "WiseMapping - Web2D Render Library",
  "homepage": "https://www.wisemapping.com/opensource/",
  "repository": {
    "type": "git",
    "url": "git@github.com:wisemapping/wisemapping-frontend.git"
  },
  "author": "Paulo Veiga <pveiga@wisemapping.com>",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist node_modules/.cache storybook-static cypress/screenshots cypress/videos debug-storybook.log .eslintcache",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "dev": "vite build --watch",
    "lint": "npx eslint src --ext js,ts",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p ${PORT:-6006} --quiet",
    "test": "yarn test:integration",
    "test:integration": "PORT=6106 node ../../scripts/run-storybook-cypress.js"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/html-vite": "^10.3.5",
    "cypress": "^15.13.1",
    "cypress-image-snapshot": "^4.0.1",
    "eslint-plugin-storybook": "^10.3.5",
    "storybook": "^10.3.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.com"
  }
}
