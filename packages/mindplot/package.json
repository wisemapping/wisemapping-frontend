{
  "name": "@wisemapping/mindplot",
  "version": "6.0.1",
  "description": "WiseMapping - Mindplot Canvas Library",
  "homepage": "https://www.wisemapping.com/opensource/",
  "repository": {
    "type": "git",
    "url": "git@github.com:wisemapping/wisemapping-frontend.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "author": "Paulo Veiga <pveiga@wisemapping.com>",
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "vite build",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist node_modules/.cache storybook-static cypress/screenshots cypress/videos debug-storybook.log .eslintcache",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "dev": "vite build --watch",
    "lint": "eslint src --ext js,ts",
    "lint:fix": "eslint src --ext js,ts --fix",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p ${PORT:-6006} --quiet",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "PORT=6107 node ../../scripts/run-storybook-cypress.js",
    "test:unit": "jest ./test/unit/**/*.test.ts --verbose --silent --detectOpenHandles"
  },
  "dependencies": {
    "@wisemapping/web2d": "*",
    "fflate": "^0.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lodash": "^4.18.1",
    "xml-formatter": "^3.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-links": "^10.4.3",
    "@storybook/html-vite": "^10.4.3",
    "blob-polyfill": "^9.0.20240710",
    "cypress": "^15.17.0",
    "eslint": "^10.4.1",
    "eslint-plugin-storybook": "^10.4.3",
    "jest": "^30.4.2",
    "raphael": "^2.3.0",
    "storybook": "^10.4.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.com"
  }
}
