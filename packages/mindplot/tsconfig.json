{
  "compilerOptions": {
    "outDir": "./dist/",
    "rootDir": "..",
    "sourceMap": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "target": "es2022",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "strictFunctionTypes": true,
    "rootDirs": [
      "src",
      "../web2d/src"
    ],
    "types": [
      "vite/client",
      "jest",
      "node",
      "react",
      "react-dom"
    ],
    "paths": {
      "@wisemapping/web2d": [
        "../web2d/src/index.ts"
      ],
      "@wisemapping/web2d/*": [
        "../web2d/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "libraries",
    "src/@types/**/*",
    "test/**/*"
  ],
  "exclude": [
    "./node_modules",
    "./dist",
    "storybook/**/*"
  ]
}
